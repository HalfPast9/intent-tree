{
  "name": "intent-tree",
  "version": "0.1.0",
  "private": true,
  "description": "Intent Tree foundation data layer",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:reset": "tsx scripts/reset-db.ts",
    "db:seed": "tsx scripts/seed-phase1.ts",
    "db:fresh": "npm run db:reset && npm run db:seed"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "neo4j-driver": "^5.24.0",
    "openai": "^4.68.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
